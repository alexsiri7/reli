# Requesty API key — get from https://requesty.ai
REQUESTY_API_KEY=your_requesty_api_key_here

# Requesty LLM base URL (default: https://router.requesty.ai/v1)
# REQUESTY_BASE_URL=https://router.requesty.ai/v1

# LLM model to use via Requesty (leave empty to use config.yaml defaults)
# Examples: google/gemini-2.0-flash-exp, google/gemini-1.5-pro, openai/gpt-4o
# REQUESTY_MODEL=
# REQUESTY_REASONING_MODEL=
# REQUESTY_RESPONSE_MODEL=

# Embedding model for pgvector semantic search
EMBEDDING_MODEL=text-embedding-3-small

# Ollama — optional local LLM for context agent (reduces API costs)
# Set OLLAMA_MODEL to enable (e.g. qwen2.5:7b, llama3.2:3b)
# Leave empty to use Requesty for all stages
OLLAMA_MODEL=
OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_EMBED_MODEL=nomic-embed-text

# Google OAuth (required for login)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# SECRET_KEY=  # JWT signing key

# Google Calendar OAuth redirect
# GOOGLE_REDIRECT_URI=http://localhost:8000/api/calendar/callback
# GOOGLE_AUTH_REDIRECT_URI=http://localhost:8000/api/auth/google/callback

# Google Custom Search API (optional — enables web search in chat)
# Get API key: https://console.cloud.google.com/apis/credentials
# Create search engine: https://programmablesearchengine.google.com/
GOOGLE_SEARCH_API_KEY=
GOOGLE_SEARCH_CX=

# Rate limiting
# RATE_LIMIT_ENABLED=true
# RATE_LIMIT_LLM_RPM=30
# RATE_LIMIT_API_RPM=60

# Sweep scheduler (nightly cleanup)
# SWEEP_ENABLED=true
# SWEEP_HOUR=3
# SWEEP_MINUTE=0

# Storage backend — "sqlite" (default) or "supabase"
# STORAGE_BACKEND=sqlite
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_KEY=your_supabase_anon_key_here

# Data directory (default: backend/)
# DATA_DIR=

# Token encryption key (auto-generated if not set)
# TOKEN_ENCRYPTION_KEY=

# Logging level
# LOG_LEVEL=INFO

# Cloudflare Zero Trust tunnel token
# Create tunnel at: https://one.dash.cloudflare.com → Networks → Tunnels
# Set the tunnel's public hostname to point to http://app:8000
CLOUDFLARE_TUNNEL_TOKEN=your_cf_tunnel_token_here
