# Requesty API key — get from https://requesty.ai
REQUESTY_API_KEY=your_requesty_api_key_here

# LLM model to use via Requesty (swap freely)
# Examples: google/gemini-2.0-flash-exp, google/gemini-1.5-pro, openai/gpt-4o
# These override the defaults in config.yaml
REQUESTY_MODEL=google/gemini-2.5-flash-lite
# REQUESTY_REASONING_MODEL=google/gemini-3-flash-preview
# REQUESTY_RESPONSE_MODEL=google/gemini-2.5-flash-lite

# Embedding model for ChromaDB vector search
# Use a Requesty-compatible model or "local/all-MiniLM-L6-v2" for Ollama
EMBEDDING_MODEL=text-embedding-3-small

# Ollama — optional local LLM for context agent (reduces API costs)
# Set OLLAMA_MODEL to enable (e.g. qwen2.5:7b, llama3.2:3b)
# Leave empty to use Requesty for all stages
OLLAMA_MODEL=
OLLAMA_BASE_URL=http://localhost:11434

# Google Custom Search API (optional — enables web search in chat)
# Get API key: https://console.cloud.google.com/apis/credentials
# Create search engine: https://programmablesearchengine.google.com/
GOOGLE_SEARCH_API_KEY=
GOOGLE_SEARCH_CX=

# Google OAuth2 (optional — enables login)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# SECRET_KEY=

# Rate limiting
# RATE_LIMIT_ENABLED=true
# RATE_LIMIT_LLM_RPM=10
# RATE_LIMIT_API_RPM=60

# Sweep scheduler
# SWEEP_ENABLED=true
# SWEEP_HOUR=3
# SWEEP_MINUTE=0

# Cloudflare Zero Trust tunnel token
# Create tunnel at: https://one.dash.cloudflare.com → Networks → Tunnels
# Set the tunnel's public hostname to point to http://app:8000
CLOUDFLARE_TUNNEL_TOKEN=your_cf_tunnel_token_here
