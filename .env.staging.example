# Staging environment configuration
# Copy to .env.staging and fill in secrets before deploying.

# Environment identifier — controls config file selection and secret validation
RELI_ENVIRONMENT=staging

# Requesty API key (can use the same key as production, or a separate one)
REQUESTY_API_KEY=your_staging_requesty_api_key

# Auth — required in staging (enforced by config validator)
SECRET_KEY=your_staging_secret_key

# Google OAuth — use staging-specific credentials or share with production
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_REDIRECT_URI=http://staging-host:8001/api/calendar/callback
# GOOGLE_AUTH_REDIRECT_URI=http://staging-host:8001/api/auth/google/callback

# Database — staging uses its own isolated SQLite database by default.
# Set DATABASE_URL to use a separate Postgres/Supabase instance for staging.
# DATABASE_URL=

# Sentry — automatically tagged as "staging" via RELI_ENVIRONMENT
SENTRY_DSN=

# Rate limiting — can be relaxed for testing
# RATE_LIMIT_ENABLED=true

# Logging — more verbose for staging debugging
LOG_LEVEL=DEBUG
